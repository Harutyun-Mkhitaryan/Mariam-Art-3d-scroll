---
// src/components/Gallery.astro
import { Image } from 'astro:assets';
import { artworks } from '../data/gallery';

const spacerFramesPerArtwork = 2;
const frameCount = artworks.length * (spacerFramesPerArtwork + 1) + 2;
const galleryHeight = Math.max(22000, frameCount * 460);
---

<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Armenian:wght@500;600;700&display=swap" rel="stylesheet">

<section
  id="gallery-section"
  class="gallery-shell antialiased-text"
  style={`--gallery-height: ${galleryHeight}px`}
>
  <div class="gallery-viewport">
    <div class="gallery-space">
      <article class="gallery-frame">
        <div class="gallery-title-frame">
          <span class="font-armenian">Ցուցահանդես</span>
          <h2>Mariam's Digital Art</h2>
          <div></div>
        </div>
      </article>

      {artworks.map((art, index) => {
        const isReverse = index % 2 !== 0;

        return (
          <>
            <article class="gallery-frame">
              <div class={`art-frame ${isReverse ? 'is-reverse' : ''}`}>
                <figure class="art-media">
                  <Image
                    src={art.image}
                    alt={art.title}
                    width={900}
                    class="art-image"
                    loading={index < 2 ? 'eager' : 'lazy'}
                  />
                </figure>

                <div class="art-copy">
                  <span>{art.tag}</span>
                  <h3 class="font-armenian">{art.title}</h3>
                  <p class="font-armenian">{art.desc}</p>
                </div>
              </div>
            </article>
            <article class="gallery-frame gallery-frame_spacer" aria-hidden="true"></article>
            <article class="gallery-frame gallery-frame_spacer" aria-hidden="true"></article>
          </>
        );
      })}

      <article class="gallery-frame">
        <div class="gallery-footer-frame">
          Mkhitaryan Harutyun Production · 2026
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .gallery-shell {
    --index: calc(1vw + 1vh);
    position: relative;
    min-height: calc(var(--gallery-height) + 100vh);
    background:
      radial-gradient(circle at 20% 12%, rgba(176, 144, 109, 0.12), transparent 28rem),
      linear-gradient(180deg, #1c1714 0%, #0a0908 42%, #050505 100%);
    color: #e8e3d9;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1s ease;
  }

  .gallery-shell.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .gallery-viewport {
    position: fixed;
    inset: 0;
    perspective: 1500px;
    overflow: hidden;
  }

  .gallery-space {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }

  .gallery-frame {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.25rem, 4vw, 4rem);
    transform-style: preserve-3d;
    transition: opacity 0.55s ease;
    will-change: transform, opacity;
  }

  .gallery-title-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    user-select: none;
  }

  .gallery-title-frame span {
    margin-bottom: 1rem;
    color: #a38a6b;
    font-size: clamp(0.75rem, 1.1vw, 1rem);
    font-weight: 600;
    letter-spacing: 0.2em;
  }

  .gallery-title-frame h2 {
    color: #d9cebf;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2.75rem, 8vw, 7rem);
    font-weight: 400;
    line-height: 0.95;
  }

  .gallery-title-frame div {
    width: 3rem;
    height: 1px;
    margin-top: 1.75rem;
    background: rgba(163, 138, 107, 0.4);
  }

  .art-frame {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(18rem, 0.78fr);
    align-items: center;
    gap: clamp(2.25rem, 6vw, 6.5rem);
    width: min(88vw, 74rem);
  }

  .art-frame.is-reverse {
    grid-template-columns: minmax(18rem, 0.8fr) minmax(0, 1.05fr);
  }

  .art-frame.is-reverse .art-media {
    order: 2;
  }

  .art-frame.is-reverse .art-copy {
    order: 1;
    text-align: right;
  }

  .art-media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    max-height: min(74vh, 43rem);
    margin: 0;
    overflow: visible;
  }

  .art-image {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: min(74vh, 43rem);
    object-fit: contain;
    filter: drop-shadow(0 2rem 2.5rem rgba(0, 0, 0, 0.52));
  }

  .art-copy {
    max-width: 33rem;
    padding: clamp(1rem, 2vw, 1.4rem) clamp(1rem, 2vw, 1.6rem);
    border-left: 2px solid rgba(208, 167, 109, 0.72);
    border-radius: 8px;
    background: linear-gradient(90deg, rgba(10, 8, 7, 0.78), rgba(10, 8, 7, 0.38) 68%, rgba(10, 8, 7, 0));
    box-shadow: 0 1.4rem 3rem rgba(0, 0, 0, 0.24);
    backdrop-filter: blur(7px);
  }

  .art-copy span {
    display: block;
    color: #e3ba7f;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.4;
    text-transform: uppercase;
    text-shadow: 0 0.2rem 0.9rem rgba(0, 0, 0, 0.82);
  }

  .art-copy h3 {
    margin-top: 0.75rem;
    color: #fff4e6;
    font-size: clamp(1.9rem, 3.15vw, 3.45rem);
    font-style: normal;
    font-weight: 700;
    line-height: 1.18;
    text-shadow: 0 0.25rem 1rem rgba(0, 0, 0, 0.88);
  }

  .art-copy p {
    margin-top: 1.1rem;
    color: #f2e8d9;
    font-size: clamp(1.05rem, 1.38vw, 1.22rem);
    font-style: normal;
    font-weight: 600;
    line-height: 1.85;
    text-shadow: 0 0.18rem 0.85rem rgba(0, 0, 0, 0.86);
  }

  .art-frame.is-reverse .art-copy {
    border-right: 2px solid rgba(208, 167, 109, 0.72);
    border-left: 0;
    background: linear-gradient(270deg, rgba(10, 8, 7, 0.78), rgba(10, 8, 7, 0.38) 68%, rgba(10, 8, 7, 0));
  }

  .gallery-footer-frame {
    color: #b0906d;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(0.72rem, 1vw, 1rem);
    letter-spacing: 0.28em;
    text-align: center;
    text-transform: uppercase;
    user-select: none;
  }

  .font-armenian {
    font-family: 'Noto Serif Armenian', serif;
  }

  .antialiased-text {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  :global(body) {
    scrollbar-width: none;
  }

  :global(html) {
    scrollbar-width: none;
  }

  :global(body::-webkit-scrollbar) {
    display: none;
  }

  :global(html::-webkit-scrollbar) {
    display: none;
  }

  @media (max-width: 767px) {
    .gallery-shell {
      min-height: calc(var(--gallery-height) + 100vh);
    }

    .gallery-viewport {
      perspective: 1850px;
    }

    .gallery-frame {
      align-items: center;
      padding: 1rem 0.9rem;
    }

    .gallery-title-frame {
      width: min(92vw, 30rem);
      transform: scale(1.48);
      transform-origin: center;
    }

    .gallery-title-frame span {
      margin-bottom: 1.15rem;
      color: #e3ba7f;
      font-size: clamp(1.22rem, 5.3vw, 1.62rem);
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: 0.12em;
      text-shadow: 0 0.2rem 0.9rem rgba(0, 0, 0, 0.86);
    }

    .gallery-title-frame h2 {
      font-size: clamp(4rem, 16.5vw, 5.8rem);
      line-height: 0.96;
      text-shadow: 0 0.32rem 1.2rem rgba(0, 0, 0, 0.9);
    }

    .art-frame,
    .art-frame.is-reverse {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.9rem;
      width: min(96vw, 32rem);
      transform: scale(1.32);
      transform-origin: center;
    }

    .art-frame.is-reverse .art-media,
    .art-frame.is-reverse .art-copy {
      order: initial;
      text-align: left;
    }

    .art-media {
      width: 100%;
      max-height: min(43vh, 23rem);
      justify-content: center;
    }

    .art-image {
      max-width: 100%;
      max-height: min(43vh, 23rem);
      filter: drop-shadow(0 1.25rem 1.5rem rgba(0, 0, 0, 0.5));
    }

    .art-copy {
      max-width: none;
      width: 100%;
      padding: 1rem 0.95rem 1.05rem;
      border: 1px solid rgba(208, 167, 109, 0.34);
      border-left: 4px solid rgba(227, 186, 127, 0.9);
      border-radius: 8px;
      background: rgba(8, 7, 6, 0.82);
      box-shadow: 0 1.1rem 2.2rem rgba(0, 0, 0, 0.36);
      backdrop-filter: blur(10px);
    }

    .art-frame.is-reverse .art-copy {
      border-right: 1px solid rgba(208, 167, 109, 0.34);
      border-left: 4px solid rgba(227, 186, 127, 0.9);
      background: rgba(8, 7, 6, 0.82);
    }

    .art-copy span {
      color: #f0c991;
      font-size: clamp(1rem, 4.2vw, 1.2rem);
      line-height: 1.45;
      letter-spacing: 0.1em;
    }

    .art-copy h3 {
      margin-top: 0.6rem;
      font-size: clamp(2.08rem, 8.8vw, 2.82rem);
      line-height: 1.15;
    }

    .art-copy p {
      margin-top: 0.78rem;
      font-size: clamp(1.18rem, 4.9vw, 1.42rem);
      line-height: 1.72;
      letter-spacing: 0.01em;
    }

    .gallery-footer-frame {
      max-width: 92vw;
      color: #f0c991;
      font-size: clamp(1.25rem, 5.8vw, 1.7rem);
      font-weight: 700;
      letter-spacing: 0.16em;
      line-height: 1.75;
      padding: 1rem 0.85rem;
      border-top: 1px solid rgba(227, 186, 127, 0.42);
      border-bottom: 1px solid rgba(227, 186, 127, 0.3);
      text-shadow: 0 0.25rem 1rem rgba(0, 0, 0, 0.9);
      transform: scale(1.48);
      transform-origin: center;
    }
  }

  @media (max-width: 767px) and (max-height: 720px) {
    .gallery-title-frame {
      transform: scale(1.42);
    }

    .gallery-title-frame span {
      font-size: clamp(1.12rem, 5vw, 1.42rem);
    }

    .gallery-title-frame h2 {
      font-size: clamp(3.45rem, 15vw, 5rem);
    }

    .gallery-footer-frame {
      font-size: clamp(1.1rem, 5.2vw, 1.45rem);
      transform: scale(1.36);
    }

    .art-frame,
    .art-frame.is-reverse {
      gap: 0.7rem;
      transform: scale(1.25);
    }

    .art-media,
    .art-image {
      max-height: 36vh;
    }

    .art-copy h3 {
      font-size: clamp(1.9rem, 8.4vw, 2.38rem);
    }

    .art-copy p {
      font-size: clamp(1.12rem, 4.8vw, 1.28rem);
      line-height: 1.62;
    }
  }
</style>

<script>
  const section = document.getElementById('gallery-section');
  const frames = Array.from(document.getElementsByClassName('gallery-frame'));

  if (section && frames.length) {
    const zSpacing = -1200;
    const zVals = new Array(frames.length).fill(0);
    let targetScroll = 0;
    let smoothScroll = 0;
    let isGalleryVisible = false;
    let rafId = 0;

    const setSectionHeight = () => {
      const isMobile = window.matchMedia('(max-width: 767px)').matches;
      const base = frames.length * (isMobile ? 720 : 460);
      section.style.setProperty('--gallery-height', `${Math.max(isMobile ? 36000 : 22000, base)}px`);
    };

    const updateFrames = () => {
      const isMobile = window.innerWidth < 768;
      const speed = isMobile ? 1.55 : 2.6;
      const fadeInStart = isMobile ? zSpacing * 1.95 : zSpacing * 1.55;
      const fadeInLength = isMobile ? 1180 : 640;
      const fadeOutStart = isMobile ? 620 : 360;
      const fadeOutLength = isMobile ? 980 : 520;

      frames.forEach((frame, index) => {
        zVals[index] = index * zSpacing + zSpacing + smoothScroll * speed;

        const transform = `translateZ(${zVals[index]}px)`;
        const frontFade = Math.min(1, Math.max(0, (fadeOutStart - zVals[index]) / fadeOutLength));
        const backFade = Math.min(1, Math.max(0, (zVals[index] - fadeInStart) / fadeInLength));
        const opacity = frontFade * backFade;
        frame.setAttribute('style', `transform: ${transform}; opacity: ${opacity}`);
      });
    };

    const syncTargetScroll = () => {
      targetScroll = Math.max(0, window.scrollY - section.offsetTop);
    };

    const animateFrames = () => {
      if (isGalleryVisible) {
        const isMobile = window.innerWidth < 768;
        const smoothing = isMobile ? 0.055 : 0.08;
        const maxStep = isMobile ? 42 : 110;
        const diff = targetScroll - smoothScroll;
        const easedStep = diff * smoothing;
        const clampedStep = Math.max(-maxStep, Math.min(maxStep, easedStep));
        smoothScroll += clampedStep;
        if (Math.abs(targetScroll - smoothScroll) < 0.05) {
          smoothScroll = targetScroll;
        }
        updateFrames();
      }

      rafId = window.requestAnimationFrame(animateFrames);
    };

    const revealGallery = () => {
      section.classList.add('is-visible');
      isGalleryVisible = true;
      setSectionHeight();
      syncTargetScroll();
      smoothScroll = targetScroll;
      updateFrames();
    };

    window.addEventListener('scroll', syncTargetScroll, { passive: true });
    window.addEventListener('resize', () => {
      setSectionHeight();
      syncTargetScroll();
      updateFrames();
    });

    setSectionHeight();
    syncTargetScroll();
    updateFrames();
    rafId = window.requestAnimationFrame(animateFrames);

    if (document.documentElement.classList.contains('intro-active')) {
      window.addEventListener('intro:done', revealGallery, { once: true });
    } else {
      revealGallery();
    }

    window.addEventListener('beforeunload', () => {
      window.cancelAnimationFrame(rafId);
    });
  }
</script>
