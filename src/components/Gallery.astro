---
// src/components/Gallery.astro
import { Image } from 'astro:assets';
import { artworks } from '../data/gallery';

const spacerFramesPerArtwork = 2;
const frameCount = artworks.length * (spacerFramesPerArtwork + 1) + 2;
const galleryHeight = Math.max(22000, frameCount * 460);
---

<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Armenian:wght@500;600&display=swap" rel="stylesheet">

<section
  id="gallery-section"
  class="gallery-shell antialiased-text"
  style={`--gallery-height: ${galleryHeight}px`}
>
  <div class="gallery-viewport">
    <div class="gallery-space">
      <article class="gallery-frame">
        <div class="gallery-title-frame">
          <span class="font-armenian">Ցուցահանդես</span>
          <h2>Mariam's Digital Art</h2>
          <div></div>
        </div>
      </article>

      {artworks.map((art, index) => {
        const isReverse = index % 2 !== 0;

        return (
          <>
            <article class="gallery-frame">
              <div class={`art-frame ${isReverse ? 'is-reverse' : ''}`}>
                <figure class="art-media">
                  <Image
                    src={art.image}
                    alt={art.title}
                    width={900}
                    class="art-image"
                    loading={index < 2 ? 'eager' : 'lazy'}
                  />
                </figure>

                <div class="art-copy">
                  <span>{art.tag}</span>
                  <h3 class="font-armenian">{art.title}</h3>
                  <p class="font-armenian">{art.desc}</p>
                </div>
              </div>
            </article>
            <article class="gallery-frame gallery-frame_spacer" aria-hidden="true"></article>
            <article class="gallery-frame gallery-frame_spacer" aria-hidden="true"></article>
          </>
        );
      })}

      <article class="gallery-frame">
        <div class="gallery-footer-frame">
          Mkhitaryan Harutyun Production · 2026
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .gallery-shell {
    --index: calc(1vw + 1vh);
    position: relative;
    min-height: calc(var(--gallery-height) + 100vh);
    background:
      radial-gradient(circle at 20% 12%, rgba(176, 144, 109, 0.12), transparent 28rem),
      linear-gradient(180deg, #1c1714 0%, #0a0908 42%, #050505 100%);
    color: #e8e3d9;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1s ease;
  }

  .gallery-shell.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .gallery-viewport {
    position: fixed;
    inset: 0;
    perspective: 1500px;
    overflow: hidden;
  }

  .gallery-space {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }

  .gallery-frame {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.25rem, 4vw, 4rem);
    transform-style: preserve-3d;
    transition: opacity 0.55s ease;
    will-change: transform, opacity;
  }

  .gallery-title-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    user-select: none;
  }

  .gallery-title-frame span {
    margin-bottom: 1rem;
    color: #a38a6b;
    font-size: clamp(0.75rem, 1.1vw, 1rem);
    font-weight: 600;
    letter-spacing: 0.2em;
  }

  .gallery-title-frame h2 {
    color: #d9cebf;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2.75rem, 8vw, 7rem);
    font-weight: 400;
    line-height: 0.95;
  }

  .gallery-title-frame div {
    width: 3rem;
    height: 1px;
    margin-top: 1.75rem;
    background: rgba(163, 138, 107, 0.4);
  }

  .art-frame {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(18rem, 0.78fr);
    align-items: center;
    gap: clamp(2.25rem, 6vw, 6.5rem);
    width: min(88vw, 74rem);
  }

  .art-frame.is-reverse {
    grid-template-columns: minmax(18rem, 0.8fr) minmax(0, 1.05fr);
  }

  .art-frame.is-reverse .art-media {
    order: 2;
  }

  .art-frame.is-reverse .art-copy {
    order: 1;
    text-align: right;
  }

  .art-media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-width: 0;
    max-height: min(74vh, 43rem);
    margin: 0;
    overflow: visible;
  }

  .art-image {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: min(74vh, 43rem);
    object-fit: contain;
    filter: drop-shadow(0 2rem 2.5rem rgba(0, 0, 0, 0.52));
  }

  .art-copy {
    max-width: 30rem;
  }

  .art-copy span {
    display: block;
    color: #a38a6b;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .art-copy h3 {
    margin-top: 0.75rem;
    color: #e3d8c8;
    font-size: clamp(1.7rem, 3vw, 3.25rem);
    font-style: normal;
    font-weight: 600;
    line-height: 1.22;
  }

  .art-copy p {
    margin-top: 1.1rem;
    color: #c4b7a6;
    font-size: clamp(0.98rem, 1.3vw, 1.15rem);
    font-style: normal;
    font-weight: 500;
    line-height: 1.8;
  }

  .gallery-footer-frame {
    color: #b0906d;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(0.72rem, 1vw, 1rem);
    letter-spacing: 0.28em;
    text-align: center;
    text-transform: uppercase;
    user-select: none;
  }

  .font-armenian {
    font-family: 'Noto Serif Armenian', serif;
  }

  .antialiased-text {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  :global(body) {
    scrollbar-width: none;
  }

  :global(html) {
    scrollbar-width: none;
  }

  :global(body::-webkit-scrollbar) {
    display: none;
  }

  :global(html::-webkit-scrollbar) {
    display: none;
  }

  @media (max-width: 767px) {
    .gallery-shell {
      min-height: calc(var(--gallery-height) + 100vh);
    }

    .gallery-frame {
      align-items: center;
      padding: 1rem 0.9rem;
    }

    .art-frame,
    .art-frame.is-reverse {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.9rem;
      width: min(96vw, 32rem);
      transform: scale(1.32);
      transform-origin: center;
    }

    .art-frame.is-reverse .art-media,
    .art-frame.is-reverse .art-copy {
      order: initial;
      text-align: left;
    }

    .art-media {
      width: 100%;
      max-height: min(43vh, 23rem);
      justify-content: center;
    }

    .art-image {
      max-width: 100%;
      max-height: min(43vh, 23rem);
      filter: drop-shadow(0 1.25rem 1.5rem rgba(0, 0, 0, 0.5));
    }

    .art-copy {
      max-width: none;
      width: 100%;
      padding: 0 0.2rem;
    }

    .art-copy span {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
    }

    .art-copy h3 {
      margin-top: 0.55rem;
      font-size: clamp(1.65rem, 7.4vw, 2.25rem);
      line-height: 1.18;
    }

    .art-copy p {
      margin-top: 0.7rem;
      font-size: clamp(1rem, 4.1vw, 1.12rem);
      line-height: 1.62;
      letter-spacing: 0.01em;
    }

    .gallery-footer-frame {
      max-width: 88vw;
      line-height: 1.8;
    }
  }

  @media (max-width: 767px) and (max-height: 720px) {
    .art-frame,
    .art-frame.is-reverse {
      gap: 0.7rem;
      transform: scale(1.18);
    }

    .art-media,
    .art-image {
      max-height: 36vh;
    }

    .art-copy h3 {
      font-size: clamp(1.45rem, 6.8vw, 1.95rem);
    }

    .art-copy p {
      font-size: clamp(0.96rem, 3.8vw, 1.04rem);
      line-height: 1.5;
    }
  }
</style>

<script>
  const section = document.getElementById('gallery-section');
  const frames = Array.from(document.getElementsByClassName('gallery-frame'));

  if (section && frames.length) {
    const zSpacing = -1200;
    const zVals = new Array(frames.length).fill(0);
    let targetScroll = 0;
    let smoothScroll = 0;
    let isGalleryVisible = false;
    let rafId = 0;

    const setSectionHeight = () => {
      const isMobile = window.matchMedia('(max-width: 767px)').matches;
      const base = frames.length * (isMobile ? 640 : 460);
      section.style.setProperty('--gallery-height', `${Math.max(isMobile ? 30000 : 22000, base)}px`);
    };

    const updateFrames = () => {
      const speed = window.innerWidth < 768 ? 2.05 : 2.6;

      frames.forEach((frame, index) => {
        zVals[index] = index * zSpacing + zSpacing + smoothScroll * speed;

        const transform = `translateZ(${zVals[index]}px)`;
        const frontFade = Math.min(1, Math.max(0, (360 - zVals[index]) / 520));
        const backFade = Math.min(1, Math.max(0, (zVals[index] - zSpacing * 1.55) / 640));
        const opacity = frontFade * backFade;
        frame.setAttribute('style', `transform: ${transform}; opacity: ${opacity}`);
      });
    };

    const syncTargetScroll = () => {
      targetScroll = Math.max(0, window.scrollY - section.offsetTop);
    };

    const animateFrames = () => {
      if (isGalleryVisible) {
        const smoothing = window.innerWidth < 768 ? 0.035 : 0.08;
        smoothScroll += (targetScroll - smoothScroll) * smoothing;
        if (Math.abs(targetScroll - smoothScroll) < 0.05) {
          smoothScroll = targetScroll;
        }
        updateFrames();
      }

      rafId = window.requestAnimationFrame(animateFrames);
    };

    const revealGallery = () => {
      section.classList.add('is-visible');
      isGalleryVisible = true;
      setSectionHeight();
      syncTargetScroll();
      smoothScroll = targetScroll;
      updateFrames();
    };

    window.addEventListener('scroll', syncTargetScroll, { passive: true });
    window.addEventListener('resize', () => {
      setSectionHeight();
      syncTargetScroll();
      updateFrames();
    });

    setSectionHeight();
    syncTargetScroll();
    updateFrames();
    rafId = window.requestAnimationFrame(animateFrames);

    if (document.documentElement.classList.contains('intro-active')) {
      window.addEventListener('intro:done', revealGallery, { once: true });
    } else {
      revealGallery();
    }

    window.addEventListener('beforeunload', () => {
      window.cancelAnimationFrame(rafId);
    });
  }
</script>
