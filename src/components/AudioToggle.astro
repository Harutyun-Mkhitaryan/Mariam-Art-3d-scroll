---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const audioSrc = `${base}media/ambient.mp3`;
---

<button class="soundbutton paused" type="button" aria-label="Toggle ambient music">
  <span class="soundbutton__mark" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </span>
  <span class="soundbutton__text" aria-hidden="true">SOUND</span>
</button>
<audio class="audio" src={audioSrc} loop preload="auto"></audio>

<style>
  .soundbutton {
    position: fixed;
    right: 2rem;
    bottom: 2rem;
    z-index: 120;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.28rem;
    width: 76px;
    height: 76px;
    padding: 0;
    color: #1d1309;
    border: 2px solid rgba(255, 246, 220, 0.95);
    border-radius: 999px;
    background:
      radial-gradient(circle at 32% 22%, #fff6d2 0 16%, #ffd77b 34%, #d59a32 66%, #8a5619 100%);
    box-shadow:
      0 1rem 2.4rem rgba(0, 0, 0, 0.5),
      0 0 0 5px rgba(219, 160, 58, 0.18),
      0 0 2rem rgba(255, 190, 73, 0.5);
    cursor: pointer;
    touch-action: manipulation;
    transition: opacity 0.25s ease, transform 0.25s ease, filter 0.25s ease, box-shadow 0.25s ease;
  }

  .soundbutton__mark {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 4px;
    height: 24px;
  }

  .soundbutton__mark span {
    display: block;
    width: 5px;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0.45rem rgba(255, 244, 209, 0.45);
  }

  .soundbutton__mark span:nth-child(1) {
    height: 13px;
  }

  .soundbutton__mark span:nth-child(2) {
    height: 23px;
  }

  .soundbutton__mark span:nth-child(3) {
    height: 17px;
  }

  .soundbutton__text {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    font-size: 0.52rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1;
    text-shadow: 0 1px 0 rgba(255, 239, 195, 0.38);
  }

  .soundbutton:hover {
    transform: scale(1.08);
    filter: saturate(1.15) brightness(1.08);
  }

  .soundbutton.paused {
    opacity: 0.9;
    filter: saturate(0.95) brightness(0.96);
  }

  .soundbutton:not(.paused) .soundbutton__mark span {
    animation: soundPulse 0.85s ease-in-out infinite alternate;
  }

  .soundbutton:not(.paused) .soundbutton__mark span:nth-child(2) {
    animation-delay: 0.13s;
  }

  .soundbutton:not(.paused) .soundbutton__mark span:nth-child(3) {
    animation-delay: 0.26s;
  }

  @keyframes soundPulse {
    from {
      transform: scaleY(0.72);
    }

    to {
      transform: scaleY(1.18);
    }
  }

  @media (max-width: 767px), (hover: none) and (pointer: coarse) {
    .soundbutton {
      right: max(0.8rem, env(safe-area-inset-right));
      bottom: max(0.8rem, env(safe-area-inset-bottom));
      width: 150px;
      height: 150px;
      gap: 0.48rem;
      border-width: 3px;
      background:
        radial-gradient(circle at 32% 22%, #fff9d8 0 14%, #ffd970 31%, #d89523 62%, #70420e 100%);
      box-shadow:
        0 1.5rem 3.5rem rgba(0, 0, 0, 0.62),
        0 0 0 9px rgba(219, 160, 58, 0.2),
        0 0 3rem rgba(255, 190, 73, 0.7);
    }

    .soundbutton__mark {
      gap: 8px;
      height: 46px;
    }

    .soundbutton__mark span {
      width: 9px;
    }

    .soundbutton__mark span:nth-child(1) {
      height: 25px;
    }

    .soundbutton__mark span:nth-child(2) {
      height: 44px;
    }

    .soundbutton__mark span:nth-child(3) {
      height: 32px;
    }

    .soundbutton__text {
      font-size: 0.9rem;
      letter-spacing: 0.1em;
    }

    .soundbutton.paused {
      opacity: 0.94;
    }
  }

  @media (max-width: 360px) {
    .soundbutton {
      width: 128px;
      height: 128px;
    }

    .soundbutton__text {
      font-size: 0.78rem;
    }
  }
</style>

<script>
  const soundButton = document.querySelector('.soundbutton');
  const audio = document.querySelector('.audio');

  if (soundButton instanceof HTMLButtonElement && audio instanceof HTMLAudioElement) {
    soundButton.addEventListener('click', () => {
      soundButton.classList.toggle('paused');

      if (audio.paused) {
        audio.play().catch(() => {
          soundButton.classList.add('paused');
        });
      } else {
        audio.pause();
      }
    });

    window.addEventListener('focus', () => {
      if (soundButton.classList.contains('paused')) {
        audio.pause();
        return;
      }

      audio.play().catch(() => {
        soundButton.classList.add('paused');
      });
    });

    window.addEventListener('blur', () => {
      audio.pause();
    });
  }
</script>
