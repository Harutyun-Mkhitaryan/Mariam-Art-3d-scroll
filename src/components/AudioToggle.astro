---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const soundIcon = `${base}images/sound.gif`;
const audioSrc = `${base}media/ambient.mp3`;
---

<button class="soundbutton paused" type="button" aria-label="Toggle ambient music">
  <img src={soundIcon} alt="" />
</button>
<audio class="audio" src={audioSrc} loop preload="auto"></audio>

<style>
  .soundbutton {
    position: fixed;
    right: 5vw;
    bottom: 5vh;
    z-index: 70;
    width: 42px;
    height: 42px;
    padding: 8px;
    border: 1px solid rgba(232, 227, 217, 0.18);
    border-radius: 999px;
    background: rgba(15, 13, 12, 0.48);
    box-shadow: 0 0.7rem 1.6rem rgba(0, 0, 0, 0.42);
    cursor: pointer;
    transition: opacity 0.25s ease, transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }

  .soundbutton img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(1.25) drop-shadow(0 0 0.45rem rgba(255, 236, 205, 0.65));
  }

  .soundbutton:hover {
    transform: scale(1.08);
    background: rgba(176, 144, 109, 0.5);
  }

  .soundbutton.paused {
    opacity: 0.52;
  }

  @media (max-width: 767px) {
    .soundbutton {
      right: max(0.75rem, env(safe-area-inset-right));
      bottom: max(0.75rem, env(safe-area-inset-bottom));
      width: 162px;
      height: 162px;
      padding: 36px;
      border: 1px solid rgba(255, 235, 196, 0.62);
      background:
        radial-gradient(circle at 34% 28%, rgba(255, 240, 204, 0.98), rgba(190, 150, 92, 0.92) 42%, rgba(56, 42, 33, 0.9) 100%);
      box-shadow:
        0 1.3rem 3rem rgba(0, 0, 0, 0.58),
        0 0 0 7px rgba(176, 144, 109, 0.14),
        0 0 2.2rem rgba(176, 144, 109, 0.48);
      backdrop-filter: blur(14px);
    }

    .soundbutton img {
      filter: brightness(0) invert(1) drop-shadow(0 0 0.7rem rgba(255, 255, 255, 0.85));
      opacity: 0.95;
    }

    .soundbutton.paused {
      opacity: 0.88;
      background:
        radial-gradient(circle at 34% 28%, rgba(244, 218, 173, 0.9), rgba(153, 112, 67, 0.86) 44%, rgba(36, 29, 25, 0.92) 100%);
      box-shadow:
        0 1.1rem 2.4rem rgba(0, 0, 0, 0.52),
        0 0 0 6px rgba(176, 144, 109, 0.12);
    }

    .soundbutton.paused img {
      opacity: 0.72;
    }
  }

  @media (max-width: 360px) {
    .soundbutton {
      width: 138px;
      height: 138px;
      padding: 31px;
    }
  }
</style>

<script>
  const soundButton = document.querySelector('.soundbutton');
  const audio = document.querySelector('.audio');

  if (soundButton instanceof HTMLButtonElement && audio instanceof HTMLAudioElement) {
    soundButton.addEventListener('click', () => {
      soundButton.classList.toggle('paused');

      if (audio.paused) {
        audio.play().catch(() => {
          soundButton.classList.add('paused');
        });
      } else {
        audio.pause();
      }
    });

    window.addEventListener('focus', () => {
      if (soundButton.classList.contains('paused')) {
        audio.pause();
        return;
      }

      audio.play().catch(() => {
        soundButton.classList.add('paused');
      });
    });

    window.addEventListener('blur', () => {
      audio.pause();
    });
  }
</script>
