---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const soundIcon = `${base}images/sound.gif`;
const audioSrc = `${base}media/ambient.mp3`;
---

<button class="soundbutton paused" type="button" aria-label="Toggle ambient music">
  <img src={soundIcon} alt="" />
</button>
<audio class="audio" src={audioSrc} loop preload="auto"></audio>

<style>
  .soundbutton {
    position: fixed;
    right: 5vw;
    bottom: 5vh;
    z-index: 70;
    width: 24px;
    height: 24px;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .soundbutton img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .soundbutton:hover {
    transform: scale(1.08);
  }

  .soundbutton.paused {
    opacity: 0.25;
  }
</style>

<script>
  const soundButton = document.querySelector('.soundbutton');
  const audio = document.querySelector('.audio');

  if (soundButton instanceof HTMLButtonElement && audio instanceof HTMLAudioElement) {
    soundButton.addEventListener('click', () => {
      soundButton.classList.toggle('paused');

      if (audio.paused) {
        audio.play().catch(() => {
          soundButton.classList.add('paused');
        });
      } else {
        audio.pause();
      }
    });

    window.addEventListener('focus', () => {
      if (soundButton.classList.contains('paused')) {
        audio.pause();
        return;
      }

      audio.play().catch(() => {
        soundButton.classList.add('paused');
      });
    });

    window.addEventListener('blur', () => {
      audio.pause();
    });
  }
</script>
